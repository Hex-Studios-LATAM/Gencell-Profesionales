generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DOCTOR
}

enum UserStatus {
  PENDING_ACTIVATION
  ACTIVE
  INACTIVE
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProfileChangeStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProfileChangeField {
  NAME_EDIT
}

enum Status {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
}

enum AudienceType {
  ALL_DOCTORS
  BY_SPECIALTY
}

enum ContentType {
  ARTICLE
  NEWS
  WHITE_PAPER
}

enum LeadSource {
  HOME_CTA
  PRODUCT_CTA
  NEWS_CTA
  WHITE_PAPER_CTA
  ARTICLE_CTA
  ELEMENTOR_FORM
  EXTERNAL_FORM
}

enum LeadChannel {
  PORTAL
  WEBSITE
}

enum LeadIntent {
  PERSONALIZED_ATTENTION
  ORDER_REQUEST
  GENERAL_INQUIRY
}

enum LeadStatus {
  NEW
  CONTACTED
  IN_PROGRESS
  CLOSED
  DISCARDED
}

model User {
  id                     String     @id @default(uuid())
  name                   String
  email                  String     @unique
  professionalLicense    String?    @unique
  passwordHash           String?
  mustSetPassword        Boolean    @default(false)
  passwordSetupToken     String?    @unique
  passwordSetupExpiresAt DateTime?
  role                   Role       @default(DOCTOR)
  status                 UserStatus @default(INACTIVE)
  phone                  String?
  profileImage           String?
  specialtyId            String?
  specialty              Specialty? @relation(fields: [specialtyId], references: [id])
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  reviewedApplications ProfessionalApplication[] @relation("ApplicationReviewer")
  articles             Article[]
  leads                Lead[]
  profileChangeRequests  ProfileChangeRequest[]
  reviewedProfileChanges ProfileChangeRequest[] @relation("ProfileChangeReviewer")
}

model ProfessionalApplication {
  id                  String            @id @default(uuid())
  name                String
  email               String            @unique
  phone               String
  professionalLicense String            @unique
  specialtyText       String
  status              ApplicationStatus @default(PENDING)
  rejectionReason     String?           @db.Text
  notes               String?           @db.Text
  reviewedAt          DateTime?
  reviewedById        String?
  reviewer            User?             @relation("ApplicationReviewer", fields: [reviewedById], references: [id])
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

model Specialty {
  id                 String             @id @default(uuid())
  name               String             @unique
  slug               String             @unique
  description        String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  products           ProductSpecialty[]
  articleSpecialties ArticleSpecialty[]
  users              User[]
}

model ArticleCategory {
  id        String    @id @default(uuid())
  name      String    @unique
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  articles  Article[]
}

model ProductCategory {
  id        String    @id @default(uuid())
  name      String    @unique
  slug      String    @unique
  logoUrl   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Article {
  id           String           @id @default(uuid())
  title        String
  slug         String           @unique
  content      String           @db.Text
  excerpt      String?          @db.Text
  imageUrl     String?
  contentType  ContentType      @default(ARTICLE)
  status       Status           @default(DRAFT)
  audienceType AudienceType     @default(ALL_DOCTORS)
  categoryId   String
  category     ArticleCategory  @relation(fields: [categoryId], references: [id])
  authorId     String?
  author       User?            @relation(fields: [authorId], references: [id])
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  specialties  ArticleSpecialty[]
}

model Product {
  id          String             @id @default(uuid())
  name        String
  slug        String             @unique
  description String             @db.Text
  imageUrl    String?
  status      Status             @default(DRAFT)
  categoryId  String
  category    ProductCategory    @relation(fields: [categoryId], references: [id])
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  specialties ProductSpecialty[]
}

model ProductSpecialty {
  productId   String
  specialtyId String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  specialty   Specialty @relation(fields: [specialtyId], references: [id], onDelete: Cascade)

  @@id([productId, specialtyId])
}

model ArticleSpecialty {
  articleId   String
  specialtyId String
  article     Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  specialty   Specialty @relation(fields: [specialtyId], references: [id], onDelete: Cascade)

  @@id([articleId, specialtyId])
}

model Lead {
  id          String      @id @default(uuid())
  name        String
  email       String
  phone       String?
  message     String?     @db.Text
  sourceType  LeadSource
  sourceId    String?
  sourceLabel String?
  intent      LeadIntent  @default(PERSONALIZED_ATTENTION)
  status      LeadStatus  @default(NEW)

  // Canal y trazabilidad de origen
  channel     LeadChannel @default(PORTAL)
  websiteName String?
  formName    String?
  pageUrl     String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  rawPayload  Json?

  userId    String?
  user      User?  @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProfileChangeRequest {
  id              String              @id @default(uuid())
  userId          String
  user            User                @relation(fields: [userId], references: [id])
  fieldType       ProfileChangeField  @default(NAME_EDIT)
  currentValue    String
  requestedValue  String
  status          ProfileChangeStatus @default(PENDING)
  reviewedAt      DateTime?
  reviewedById    String?
  reviewer        User?               @relation("ProfileChangeReviewer", fields: [reviewedById], references: [id])
  rejectionReason String?             @db.Text
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}